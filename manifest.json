{
  "manifest_version": 3,
  "name": "Azure DevOps PR Tracker",
  "version": "1.0",
  "description": "Track progress and receive notifications for Azure DevOps Pull Requests.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://dev.azure.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://dev.azure.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Azure DevOps PR Tracker",
    "default_icon": "icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
